# ── Gmail Setup ────────────────────────────────────────────────────────────────
# Step 1: myaccount.google.com → Security → 2-Step Verification (enable)
# Step 2: myaccount.google.com → Security → App passwords
# Step 3: Create app password for "Mail" → paste the 16-char code below

GMAIL_USER=mollylmangan@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ── Admin sync key (make this something random & secret) ───────────────────────
ADMIN_KEY=change_me_to_something_secret

# ── Port (Railway sets this automatically) ─────────────────────────────────────
PORT=3001
